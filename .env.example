# Copy to .env and adjust if your Postgres setup differs from Postgres.app defaults.
# Postgres.app: the superuser is your macOS username, with no password, on localhost.
# load_data.py auto-builds this from your OS user if DATABASE_URL is unset, so you
# usually do not need a .env at all.

DATABASE_URL=postgresql+psycopg2://YOUR_MAC_USERNAME@localhost:5432/harborline
